#!/bin/bash
set -euo pipefail

CONFIG="$HOME/.config/hyprvoice/config.toml"
MODELS=("small.en" "large-v3-turbo")

current=$(grep '^model' "$CONFIG" | head -1 | sed 's/.*= *"\(.*\)"/\1/')

if [ "$current" = "${MODELS[0]}" ]; then
  next="${MODELS[1]}"
else
  next="${MODELS[0]}"
fi

sed -i "0,/^model = \"$current\"/s//model = \"$next\"/" "$CONFIG"
notify-send "Hyprvoice" "Model: $next"
